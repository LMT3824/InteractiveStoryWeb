@page
@{
    ViewData["Title"] = "Đặt lại mật khẩu thành công";
}

<div class="text-center">
    <h1 class="text-success mb-3">@ViewData["Title"]</h1>
    <p>Bạn đã đặt lại mật khẩu thành công.</p>
    <p>Bây giờ bạn có thể đăng nhập bằng mật khẩu mới của mình.</p>
    <a class="btn btn-primary mt-3" asp-page="/Account/Login">Quay về đăng nhập</a>
</div>
