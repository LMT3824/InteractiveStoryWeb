@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<link href="https://fonts.googleapis.com/css2?family=STIX+Two+Text:wght@400;700&display=swap" rel="stylesheet">

<style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100vh;
        overflow-x: hidden;
    }

    .background-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to right, #FFE6CE 50%, #FFFBF8 50%);
        z-index: -1;
    }

    .main-content {
        position: relative;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        width: 100%;
        margin-top: 20px;
    }

    .reset-password-container {
        width: 670px;
        height: 670px;
        background-color: #ffffff;
        border: 1px solid #e0e0e0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

        .reset-password-container h1 {
            font-size: 42px;
            color: #000000;
            margin-bottom: 10px;
            font-family: 'STIX Two Text', serif;
            font-weight: 700;
        }

        .reset-password-container p {
            font-size: 20px;
            color: #000000;
            margin-bottom: 30px;
        }

    .form-group {
        margin-bottom: 20px;
        width: 500px;
    }

        .form-group label {
            display: block;
            color: #000000;
            font-size: 20px;
            margin-bottom: 5px;
        }

        .form-group input {
            width: 100%;
            height: 60px;
            border: 2px solid #672B00;
            border-radius: 5px;
            font-size: 18px;
            padding: 10px;
            box-sizing: border-box;
        }

    .btn-success {
        width: 250px;
        height: 50px;
        background-color: #5B2A00;
        color: #ffffff;
        border: none;
        border-radius: 5px;
        font-size: 23px;
        cursor: pointer;
        display: block;
        margin: 20px auto;
    }

        .btn-success:hover {
            background-color: #4a2300;
        }

    .text-danger {
        font-size: 16px;
        color: #ff0000;
        text-align: center;
        margin-top: 10px;
    }
</style>

<div class="background-container"></div>
<div class="main-content">
    <div class="reset-password-container">
        <h1>@ViewData["Title"]</h1>
        <p>Vui lòng nhập email và mật khẩu mới để khôi phục tài khoản của bạn.</p>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <!-- Mã xác nhận -->
            <input asp-for="Input.Code" type="hidden" />

            <!-- Email -->
            <div class="form-group">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" placeholder="Email..." />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <!-- Mật khẩu mới -->
            <div class="form-group">
                <label asp-for="Input.Password">Mật khẩu mới</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Mật khẩu mới..." />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <!-- Xác nhận mật khẩu -->
            <div class="form-group">
                <label asp-for="Input.ConfirmPassword">Xác nhận mật khẩu</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu..." />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">ĐẶT LẠI MẬT KHẨU</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}