@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<link href="https://fonts.googleapis.com/css2?family=STIX+Two+Text:wght@400;700&display=swap" rel="stylesheet">

<style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100vh;
        overflow-x: hidden;
    }

    .background-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to right, #FFE6CE 50%, #FFFBF8 50%);
        z-index: -1;
    }

    .main-content {
        position: relative;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        width: 100%;
        margin-top: 20px;
    }

    .change-password-container {
        width: 620px;
        height: 630px;
        background-color: #ffffff;
        border: 1px solid #e0e0e0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

        .change-password-container h2 {
            font-size: 42px;
            color: #000000;
            margin-bottom: 30px;
            font-family: 'STIX Two Text', serif;
            font-weight: 700;
        }

    .form-group {
        margin-bottom: 20px;
        width: 500px;
    }

        .form-group label {
            display: block;
            color: #000000;
            font-size: 20px;
            margin-bottom: 5px;
        }

        .form-group input {
            width: 100%;
            height: 60px;
            border: 2px solid #672B00;
            border-radius: 5px;
            font-size: 18px;
            padding: 10px;
            box-sizing: border-box;
        }

    .btn-primary {
        width: 200px;
        height: 50px;
        background-color: #5B2A00;
        color: #ffffff;
        border: none;
        border-radius: 5px;
        font-size: 23px;
        cursor: pointer;
        display: block;
        margin: 20px auto;
    }

        .btn-primary:hover {
            background-color: #4a2300;
        }

    .text-danger {
        font-size: 16px;
        color: #ff0000;
        text-align: center;
        margin-top: 10px;
    }
</style>

<div class="background-container"></div>
<div class="main-content">
    <div class="change-password-container">
        <h2>Đổi mật khẩu</h2>

        <form method="post">
            <!-- Current Password -->
            <div class="form-group">
                <label asp-for="Input.CurrentPassword">Mật khẩu hiện tại</label>
                <input asp-for="Input.CurrentPassword" class="form-control" type="password" autocomplete="current-password" aria-required="true" placeholder="Mật khẩu hiện tại..." />
                <span asp-validation-for="Input.CurrentPassword" class="text-danger"></span>
            </div>

            <!-- New Password -->
            <div class="form-group">
                <label asp-for="Input.NewPassword">Mật khẩu mới</label>
                <input asp-for="Input.NewPassword" class="form-control" type="password" autocomplete="new-password" aria-required="true" placeholder="Mật khẩu mới..." />
                <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
            </div>

            <!-- Confirm Password -->
            <div class="form-group">
                <label asp-for="Input.ConfirmPassword">Xác nhận mật khẩu</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" type="password" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu..." />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">ĐỔI MẬT KHẨU</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}