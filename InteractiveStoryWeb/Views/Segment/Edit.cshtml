@model InteractiveStoryWeb.ViewModels.ChapterSegmentEditViewModel

@{
    ViewData["Title"] = "Chỉnh sửa đoạn truyện";
}

<link href="https://fonts.googleapis.com/css2?family=STIX+Two+Text&display=swap" rel="stylesheet">

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

        .page-header .back-arrow {
            cursor: pointer;
            color: #000;
            text-decoration: none;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            vertical-align: middle;
        }

            .page-header .back-arrow:hover {
                background: rgba(122,75,22,0.1);
                color: #000000;
            }

            .page-header .back-arrow svg {
                width: 100%;
                height: 100%;
            }

        .page-header h2 {
            font-family: 'STIX Two Text', serif;
            font-weight: 700;
            font-size: 32px;
            margin-top: 26px;
            margin-bottom: 20px;
            line-height: 30px;
        }

    .chapter-header {
        max-width: 1600px;
        width: 100%;
        background-color: #FEE6D0;
        border: 2px solid #A6724E;
        border-radius: 15px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        padding: 20px;
        margin: 0 auto 20px auto;
        text-align: center;
    }

    .story-title, .chapter-title {
        font-family: 'STIX Two Text', serif;
        font-size: 26px;
        font-weight: 700;
        color: #000000;
        margin: 0;
        line-height: 1.5;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        text-align: center;
    }

    .edit-badge {
        display: inline-block;
        background-color: #ffc107;
        color: #000;
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 14px;
        font-weight: 600;
        margin-top: 10px;
    }

    .upper-content-container {
        max-width: 1600px;
        width: 100%;
        margin: 0 auto;
        text-align: center;
    }

    .content-container {
        max-width: 1000px;
        width: 100%;
        margin: 0 auto;
    }

    .control-bar {
        display: flex;
        justify-content: center;
        align-items: center;
        margin-bottom: 20px;
        gap: 15px;
    }

    hr {
        border: 0;
        height: 1px;
        background: #000000;
        margin: 20px 0;
    }

    .form-section {
        background-color: #fff;
        border: 2px solid #A6724E;
        border-radius: 10px;
        padding: 25px;
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        color: #000;
        margin-bottom: 8px;
    }

    .form-control, .form-select {
        border: 1px solid #A6724E;
        border-radius: 5px;
    }

        .form-control:focus, .form-select:focus {
            border-color: #7a4b16;
            box-shadow: 0 0 0 0.2rem rgba(122, 75, 22, 0.25);
        }

    textarea.form-control {
        font-family: 'STIX Two Text', serif;
        font-size: 18px;
        line-height: 1.6;
    }

    .segment-image {
        max-width: 950px;
        width: 100%;
    }

    .btn-action {
        padding: 10px 20px;
        font-size: 16px;
        border-radius: 5px;
        margin: 5px;
    }

    .btn-success {
        background-color: #28a745;
        border-color: #28a745;
    }

    .btn-info {
        background-color: #17a2b8;
        border-color: #17a2b8;
    }

    .btn-secondary {
        background-color: #6c757d;
        border-color: #6c757d;
    }

    #previewContent {
        font-size: 20px;
        text-align: justify;
        background-color: #f8f9fa;
        border: 2px solid #A6724E;
        border-radius: 10px;
        padding: 20px;
    }

        #previewContent p {
            margin-bottom: 0.5em;
            white-space: pre-wrap;
        }

        #previewContent .segment-image {
            max-width: 950px;
            width: 100%;
        }

    .image-preview-container {
        text-align: center;
        margin-top: 15px;
    }

        .image-preview-container img {
            max-height: 300px;
            border: 2px solid #A6724E;
            border-radius: 5px;
        }

    .helper-text {
        font-size: 14px;
        color: #6c757d;
        margin-top: 8px;
    }

        .helper-text code {
            background-color: #f8f9fa;
            padding: 2px 6px;
            border-radius: 3px;
            font-size: 13px;
        }

        .helper-text ul {
            margin-top: 10px;
            padding-left: 20px;
        }

        .helper-text li {
            margin-bottom: 5px;
        }
</style>

<div class="page-header">
    <a asp-controller="Chapter" asp-action="Manage" asp-route-storyId="@ViewBag.StoryId" class="back-arrow">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
    </a>
    <h2>CHỈNH SỬA ĐOẠN TRUYỆN</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="chapter-header">
    <h3 class="story-title">@ViewBag.StoryTitle</h3>
    <span class="edit-badge">Chế độ chỉnh sửa</span>
</div>

<div class="upper-content-container">
    <h4 class="chapter-title">@ViewBag.ChapterTitle</h4>
    <div class="control-bar">
        <button type="button" class="btn btn-info btn-action" id="previewButton">
            <i class="bi bi-eye"></i> Xem trước
        </button>
    </div>
</div>

<hr />

<div class="content-container">
    <form asp-action="Edit" method="post" enctype="multipart/form-data" id="editSegmentForm">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ChapterId" />
        <input type="hidden" asp-for="CreatedAt" />
        <input type="hidden" asp-for="ImageUrl" />

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="form-section">
            <div class="mb-3">
                <label asp-for="Title" class="form-label">Tiêu đề đoạn</label>
                <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề đoạn..." />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label">Nội dung đoạn</label>
                <textarea asp-for="Content" rows="20" class="form-control" placeholder="Nhập nội dung đoạn..." id="contentInput"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
                <div class="helper-text">
                    @if (ViewBag.AllowCustomization == true)
                    {
                        <div>
                            <strong>Từ khóa tùy chỉnh:</strong> Bạn có thể dùng <code>[Tên]</code>, <code>[XưngHôThứNhất]</code>, <code>[XưngHôThứHai]</code>
                        </div>
                        <br />
                    }
                    <strong>Hỗ trợ Markdown:</strong>
                    <ul>
                        <li><code>*nghiêng*</code> → <em>nghiêng</em></li>
                        <li><code>**đậm**</code> → <strong>đậm</strong></li>
                        <li><code>***đậm và nghiêng***</code> → <strong><em>đậm và nghiêng</em></strong></li>
                    </ul>
                </div>
            </div>

            <div class="mb-3">
                <label for="NewImage" class="form-label">Ảnh minh họa</label>
                <input type="file" name="NewImage" class="form-control" accept="image/*" id="newImageInput" />
                <div class="helper-text">
                    Chọn ảnh minh họa mới (định dạng: jpg, png, ...). Nếu không chọn ảnh mới, ảnh hiện tại sẽ được giữ nguyên.
                </div>
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="image-preview-container">
                        <p><strong>Ảnh hiện tại:</strong></p>
                        <img src="@Model.ImageUrl" alt="Ảnh minh họa" />
                    </div>
                }
                else
                {
                    <div class="helper-text mt-2">
                        <em>Chưa có ảnh minh họa.</em>
                    </div>
                }
            </div>

            <div class="mb-3">
                <label asp-for="ImagePosition" class="form-label">Vị trí ảnh</label>
                <select asp-for="ImagePosition" class="form-select">
                    <option value="Top">Đầu trang</option>
                    <option value="Bottom">Cuối trang</option>
                </select>
            </div>
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-success btn-action">
                <i class="bi bi-save"></i> Lưu thay đổi
            </button>
            <button type="button" class="btn btn-info btn-action" id="previewButtonBottom">
                <i class="bi bi-eye"></i> Xem trước
            </button>
            <a asp-controller="Chapter" asp-action="Manage" asp-route-storyId="@ViewBag.StoryId" class="btn btn-secondary btn-action">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </form>
</div>

<hr />

<!-- Khu vực xem trước -->
<div class="content-container mt-4" id="previewArea" style="display: none;">
    <div class="chapter-header">
        <h4 class="story-title">Xem trước nội dung</h4>
    </div>
    <div id="previewContent"></div>
    <div class="text-center mt-3">
        <button type="button" class="btn btn-secondary btn-action" id="closePreview">
            <i class="bi bi-x-circle"></i> Đóng xem trước
        </button>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Xử lý submit form
            $('#editSegmentForm').on('submit', function (e) {
                var newImage = $('#newImageInput')[0].files[0];
                var imageUrl = $('#ImageUrl').val();
                console.log("Submitting form. NewImage:", newImage, "ImageUrl:", imageUrl);

                if (!newImage && !imageUrl) {
                    console.log("No image provided. Submitting form without image.");
                }
            });

            // Hàm xử lý xem trước
            function showPreview() {
                var content = $('#contentInput').val();
                var chapterId = $('#ChapterId').val();
                var imagePosition = $('#ImagePosition').val();
                var imageUrl = $('#ImageUrl').val();
                var newImageFile = $('#newImageInput')[0].files[0];

                var formData = new FormData();
                formData.append('ChapterId', chapterId);
                formData.append('Content', content);
                formData.append('ImagePosition', imagePosition);
                formData.append('ImageUrl', imageUrl);
                if (newImageFile) {
                    formData.append('image', newImageFile);
                }
                formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

                console.log("Sending preview request with NewImage:", newImageFile);

                $.ajax({
                    url: '@Url.Action("Preview", "Segment")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        if (response.success) {
                            $('#previewContent').html(response.previewContent);
                            $('#previewArea').show();
                            // Cuộn xuống khu vực xem trước
                            $('html, body').animate({
                                scrollTop: $('#previewArea').offset().top - 20
                            }, 500);
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function () {
                        alert('Có lỗi xảy ra khi xem trước.');
                    }
                });
            }

            // Xử lý nút xem trước (cả 2 vị trí)
            $('#previewButton, #previewButtonBottom').click(function () {
                showPreview();
            });

            // Xử lý nút đóng xem trước
            $('#closePreview').click(function () {
                $('#previewArea').hide();
                // Cuộn lên đầu form
                $('html, body').animate({
                    scrollTop: $('#editSegmentForm').offset().top - 20
                }, 500);
            });
        });
    </script>
}