@model InteractiveStoryWeb.ViewModels.ChapterSegmentEditViewModel

@{
    ViewData["Title"] = "Chỉnh sửa đoạn truyện";
}

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

        .page-header .back-arrow {
            cursor: pointer;
            color: #000;
            text-decoration: none;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            vertical-align: middle;
        }

            .page-header .back-arrow:hover {
                background: rgba(122, 75, 22, 0.1);
                color: #000;
            }

            .page-header .back-arrow svg {
                width: 100%;
                height: 100%;
            }

        .page-header h2 {
            font-family: 'STIX Two Text', serif;
            font-weight: 700;
            font-size: 32px;
            margin-top: 26px;
            margin-bottom: 20px;
            line-height: 30px;
        }
</style>

<div class="page-header">
    <a href="javascript:history.back()" class="back-arrow">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
    </a>
    <h2>CHỈNH SỬA ĐOẠN TRUYỆN</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="Edit" method="post" enctype="multipart/form-data" id="editSegmentForm">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ChapterId" />
    <input type="hidden" asp-for="CreatedAt" />
    <input type="hidden" asp-for="ImageUrl" />

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label">Tiêu đề đoạn</label>
        <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề đoạn..." />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Content" class="form-label">Nội dung đoạn</label>
        <textarea asp-for="Content" rows="40" class="form-control" placeholder="Nhập nội dung đoạn..." id="contentInput"></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
        <small class="form-text text-muted">
            @if (ViewBag.AllowCustomization == true)
            {
                <text>Bạn có thể dùng các từ khóa: [Tên], [XưngHôThứNhất], [XưngHôThứHai]. Chúng sẽ được thay thế bằng thông tin người đọc nhập.</text>
                <br></br>
            }
            Hỗ trợ Markdown:
            <ul>
                <li><code>*nghiêng*</code> → <em>nghiêng</em></li>
                <li><code>**đậm**</code> → <strong>đậm</strong></li>
                <li><code>***đậm và nghiêng***</code> → <strong><em>đậm và nghiêng</em></strong></li>
            </ul>
        </small>
    </div>

    <div class="mb-3">
        <label for="NewImage" class="form-label">Ảnh minh họa mới (không bắt buộc)</label>
        <input type="file" name="NewImage" class="form-control" accept="image/*" id="newImageInput" />
        <small class="form-text text-muted">Chọn ảnh minh họa mới (định dạng: jpg, png, ...). Nếu không chọn ảnh mới, ảnh hiện tại (nếu có) sẽ được giữ nguyên.</small>
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="mt-2">
                <p>Ảnh hiện tại:</p>
                <img src="@Model.ImageUrl" class="img-thumbnail" style="max-height: 200px;" alt="Ảnh minh họa" />
            </div>
        }
        else
        {
            <div class="mt-2">
                <p>Chưa có ảnh minh họa.</p>
            </div>
        }
    </div>

    <div class="mb-3">
        <label asp-for="ImagePosition" class="form-label">Vị trí ảnh</label>
        <select asp-for="ImagePosition" class="form-select">
            <option value="Top">Đầu trang</option>
            <option value="Bottom">Cuối trang</option>
        </select>
    </div>

    <button type="submit" class="btn btn-success">💾 Lưu thay đổi</button>
    <button type="button" class="btn btn-info" id="previewButton">👁️ Xem trước</button>
    <a asp-controller="Chapter" asp-action="Manage" asp-route-storyId="@ViewBag.StoryId" class="btn btn-secondary ms-2">⬅️ Quay lại</a>
</form>

<!-- Khu vực xem trước -->
<div class="mt-4" id="previewArea" style="display: none;">
    <h4>Xem trước nội dung</h4>
    <div id="previewContent" class="border p-3" style="min-height: 100px; white-space: pre-wrap; margin-bottom: 0.5em;"></div>
</div>

<style>
    #previewContent .segment-image {
        max-width: 1500px;
        width: 100%;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#editSegmentForm').on('submit', function (e) {
                // Đảm bảo không có client-side validation yêu cầu ImageUrl
                var newImage = $('#newImageInput')[0].files[0];
                var imageUrl = $('#ImageUrl').val();
                console.log("Submitting form. NewImage:", newImage, "ImageUrl:", imageUrl);

                // Nếu không có ảnh mới và không có ảnh hiện tại, vẫn cho phép submit
                if (!newImage && !imageUrl) {
                    console.log("No image provided. Submitting form without image.");
                }
            });

            $('#previewButton').click(function () {
                var content = $('#contentInput').val();
                var chapterId = $('#ChapterId').val();
                var imagePosition = $('#ImagePosition').val();
                var imageUrl = $('#ImageUrl').val();
                var newImageFile = $('#newImageInput')[0].files[0];

                var formData = new FormData();
                formData.append('ChapterId', chapterId);
                formData.append('Content', content);
                formData.append('ImagePosition', imagePosition);
                formData.append('ImageUrl', imageUrl);
                if (newImageFile) {
                    formData.append('image', newImageFile);
                }
                formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

                console.log("Sending preview request with NewImage:", newImageFile);

                $.ajax({
                    url: '@Url.Action("Preview", "Segment")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        if (response.success) {
                            $('#previewContent').html(response.previewContent);
                            $('#previewArea').show();
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function () {
                        alert('Có lỗi xảy ra khi xem trước.');
                    }
                });
            });
        });
    </script>
}