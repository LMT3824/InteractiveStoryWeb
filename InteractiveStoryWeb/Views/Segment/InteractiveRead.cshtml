@model InteractiveStoryWeb.Models.ChapterSegment

@inject Microsoft.AspNetCore.Identity.UserManager<InteractiveStoryWeb.Models.ApplicationUser> UserManager

@{
    var customization = ViewBag.Customization as InteractiveStoryWeb.Models.ReaderStoryCustomization;
    var author = Model.Chapter?.Story?.Author;
    var avatarUrl = string.IsNullOrEmpty(author?.AvatarUrl) ? "~/images/AvatarNull.jpg" : author.AvatarUrl;

    // Xác định chương trước và chương sau
    var story = Model.Chapter?.Story;
    var chapters = story?.Chapters?.Where(c => c.IsPublic).OrderBy(c => c.CreatedAt).ToList();
    var currentChapter = Model.Chapter;
    var currentIndex = chapters?.FindIndex(c => c.Id == currentChapter?.Id) ?? -1;
    var hasPreviousChapter = currentIndex > 0;
    var previousChapter = hasPreviousChapter ? chapters[currentIndex - 1] : null;
    var hasNextChapter = ViewBag.HasNextChapter == true;
    var nextChapter = hasNextChapter && currentIndex >= 0 && currentIndex < chapters.Count - 1 ? chapters[currentIndex + 1] : null;

    // Lấy segment đầu tiên của chương trước và chương sau
    var firstSegmentOfPrevious = previousChapter?.Segments?.OrderBy(s => s.Id).FirstOrDefault();
    var firstSegmentOfNext = nextChapter?.Segments?.OrderBy(s => s.Id).FirstOrDefault();

    // Sử dụng ViewBag.IsInLibrary và ViewBag.IsAuthenticated
    bool isInLibrary = ViewBag.IsInLibrary ?? false;
    bool isAuthenticated = ViewBag.IsAuthenticated ?? false;
}

<link href="https://fonts.googleapis.com/css2?family=STIX+Two+Text&display=swap" rel="stylesheet">

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

        .page-header .back-arrow {
            cursor: pointer;
            color: #000;
            text-decoration: none;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            vertical-align: middle;
        }

            .page-header .back-arrow:hover {
                background: rgba(122,75,22,0.1);
                color: #000000;
            }

            .page-header .back-arrow svg {
                width: 100%;
                height: 100%;
            }

        .page-header h2 {
            font-family: 'STIX Two Text', serif;
            font-weight: 700;
            font-size: 32px;
            margin-top: 26px;
            margin-bottom: 20px;
            line-height: 30px;
        }

    .chapter-header {
        max-width: 1600px;
        width: 100%;
        background-color: #FEE6D0;
        border: 2px solid #A6724E;
        border-radius: 15px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        padding: 20px;
        margin: 0 auto 20px auto;
        text-align: center;
    }

    .story-title, .chapter-title {
        font-family: 'STIX Two Text', serif;
        font-size: 26px;
        font-weight: 700;
        color: #000000;
        margin: 0;
        line-height: 1.5;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        text-align: center;
    }

    .author-info {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
    }

        .author-info a {
            color: #000000;
            text-decoration: none;
            font-size: 20px;
        }

            .author-info a:hover {
                text-decoration: underline;
            }

    .author-avatar {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        object-fit: cover;
    }

    .upper-content-container {
        max-width: 1600px;
        width: 100%;
        margin: 0 auto;
        text-align: center;
    }

    .content-container {
        max-width: 1000px;
        width: 100%;
        margin: 0 auto;
        text-align: center;
    }

    .chapter-meta {
        margin-bottom: 15px;
    }

        .chapter-meta p {
            margin: 5px 0;
            font-size: 14px;
            color: #555;
        }

        .chapter-meta .time-info {
            display: inline;
        }

        .chapter-meta .separator {
            margin: 0 5px;
        }

    .control-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        position: relative;
    }

        .control-bar .left-controls,
        .control-bar .right-controls {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .control-bar .navigation-controls {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
        }

        .control-bar a,
        .control-bar button {
            color: #000000;
            text-decoration: none;
            font-size: 18px;
            background: none;
            border: none;
            cursor: pointer;
        }

            .control-bar a:hover,
            .control-bar button:hover {
                text-decoration: underline;
            }

        .control-bar .separator {
            color: #000000;
            font-size: 18px;
            margin: 0 10px;
        }

    .card-body p {
        margin-bottom: 0.5em;
        white-space: pre-wrap;
    }

    .card-body br {
        content: "";
    }

    .card-body ul {
        margin-left: 20px;
    }

    .card-body li {
        margin-bottom: 0.5em;
    }

    .choice-button {
        color: #000;
        overflow-wrap: break-word;
        max-width: 100%;
        white-space: normal;
        text-align: center;
        font-size: 20px;
    }

    .list-group-item {
        word-break: break-word;
    }

    .segment-image {
        max-width: 950px;
        width: 100%;
    }

    hr {
        border: 0;
        height: 1px;
        background: #000000;
        margin: 20px 0;
    }

    #segment-text {
        font-size: 20px;
        text-align: justify;
    }

    #segment-content {
        border: none;
        background: none;
    }

    #choices-container .list-group,
    #choices-container .list-group-item {
        border: none;
        background: none;
    }
</style>

@Html.AntiForgeryToken()

<div id="alert-container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
</div>

<div class="page-header">
    <a asp-controller="Story" asp-action="Details" asp-route-id="@Model.Chapter.StoryId" class="back-arrow">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
    </a>
    <h2>ĐỌC TRUYỆN</h2>
</div>

<div class="chapter-header" id="chapter-header">
    <h3 class="story-title">@Model.Chapter.Story.Title</h3>
    <div class="author-info">
        <img src="@(string.IsNullOrEmpty(@author?.AvatarUrl) ? Url.Content("~/images/AvatarNull.jpg") : @author?.AvatarUrl)" alt="Avatar" class="author-avatar" />
        <a href="@Url.Action("Profile", "Account", new { id = author?.Id })" title="Xem trang cá nhân">
            @author?.UserName
        </a>
    </div>
</div>

<div class="upper-content-container">
    <h4 class="chapter-title" id="chapter-title">@Model.Chapter.Title</h4>

    <div class="chapter-meta" id="chapter-meta">
        <p>
            <span class="time-info">Thời gian đăng: @Model.Chapter.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
            @if (Model.Chapter.UpdatedAt.HasValue)
            {
                <span class="separator">|</span>
                <span class="time-info">Thời gian chỉnh sửa: @Model.Chapter.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</span>
            }
        </p>
    </div>

    <div class="control-bar" id="control-bar">
        <div class="left-controls">
            @if (Model.Chapter.Story.AllowCustomization)
            {
                <a href="@Url.Action("Customize", "Story", new { storyId = Model.Chapter.StoryId })">Tùy chỉnh nhân vật</a>
                <span class="separator">|</span>
                <a href="@Url.Action("TOS", "Story")" title="Điều khoản tùy chỉnh nhân vật">Tìm hiểu thêm</a>
            }
        </div>

        <div class="navigation-controls">
            <button class="btn btn-link prev-chapter" data-current-chapter-id="@Model.Chapter.Id"> &lt; Chương trước</button>
            <span class="separator">|</span>
            <a href="@Url.Action("Details", "Story", new { id = Model.Chapter.StoryId })">Mục lục</a>
            <span class="separator">|</span>
            <button class="btn btn-link next-chapter" data-current-chapter-id="@Model.Chapter.Id">Chương sau > </button>
        </div>

        <div class="right-controls">
            <form class="library-form d-inline" data-action="@(isInLibrary ? "RemoveFromLibrary" : "AddToLibrary")" data-story-id="@Model.Chapter.StoryId">
                <input type="hidden" name="storyId" value="@Model.Chapter.StoryId" />
                @if (!isAuthenticated)
                {
                    <button type="button" class="btn btn-link library-btn" onclick="alert('Bạn phải đăng nhập mới có thể lưu truyện vào thư viện.')">
                        @(isInLibrary ? "Xóa khỏi thư viện" : "Lưu vào thư viện")
                    </button>
                }
                else
                {
                    <button type="submit" class="btn btn-link library-btn">
                        @(isInLibrary ? "Xóa khỏi thư viện" : "Lưu vào thư viện")
                    </button>
                }
            </form>
        </div>
    </div>
</div>

<hr />

<div class="content-container">
    <div id="segment-content">
        <div class="card-body">
            @if (!string.IsNullOrEmpty(Model.ImageUrl) && Model.ImagePosition == ImagePosition.Top)
            {
                <div class="text-center mb-3">
                    <img src="@Model.ImageUrl" class="img-fluid rounded shadow segment-image" alt="Ảnh minh họa" />
                </div>
            }

            <div id="segment-text">
                @Html.Raw(Model.Content)
            </div>

            @if (!string.IsNullOrEmpty(Model.ImageUrl) && Model.ImagePosition == ImagePosition.Bottom)
            {
                <div class="text-center mb-3">
                    <img src="@Model.ImageUrl" class="img-fluid rounded shadow segment-image" alt="Ảnh minh họa" />
                </div>
            }
        </div>
    </div>

    <div id="choices-container">
        @if (Model.Choices != null && Model.Choices.Any())
        {
            <ul class="list-group mb-4">
                @foreach (var choice in Model.Choices.Where(c =>
               c.NextSegment != null &&
               c.NextSegment.Chapter != null &&
               c.NextSegment.Chapter.StoryId == Model.Chapter.StoryId &&
               c.NextSegment.Chapter.IsPublic))
                {
                    <li class="list-group-item">
                        <button class="btn btn-outline-dark w-100 choice-button" data-choice-id="@choice.Id">
                            @choice.ChoiceText
                        </button>
                    </li>
                }
            </ul>
        }
    </div>
</div>

<hr />

<div class="control-bar" id="control-bar">
    <div class="left-controls">
        @if (Model.Chapter.Story.AllowCustomization)
        {
            <a href="@Url.Action("Customize", "Story", new { storyId = Model.Chapter.StoryId })">Tùy chỉnh nhân vật</a>
            <span class="separator">|</span>
            <a href="@Url.Action("TOS", "Story")" title="Điều khoản tùy chỉnh nhân vật">Tìm hiểu thêm</a>
        }
    </div>

    <div class="navigation-controls">
        <button class="btn btn-link prev-chapter" data-current-chapter-id="@Model.Chapter.Id"> &lt; Chương trước</button>
        <span class="separator">|</span>
        <a href="@Url.Action("Details", "Story", new { id = Model.Chapter.StoryId })">Mục lục</a>
        <span class="separator">|</span>
        <button class="btn btn-link next-chapter" data-current-chapter-id="@Model.Chapter.Id">Chương sau > </button>
    </div>

    <div class="right-controls">
        <form class="library-form d-inline" data-action="@(isInLibrary ? "RemoveFromLibrary" : "AddToLibrary")" data-story-id="@Model.Chapter.StoryId">
            <input type="hidden" name="storyId" value="@Model.Chapter.StoryId" />
            @if (!isAuthenticated)
            {
                <button type="button" class="btn btn-link library-btn" onclick="alert('Bạn phải đăng nhập mới có thể lưu truyện vào thư viện.')">
                    @(isInLibrary ? "Xóa khỏi thư viện" : "Lưu vào thư viện")
                </button>
            }
            else
            {
                <button type="submit" class="btn btn-link library-btn">
                    @(isInLibrary ? "Xóa khỏi thư viện" : "Lưu vào thư viện")
                </button>
            }
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Hàm hiển thị thông báo
            function showAlert(type, message) {
                $('#alert-container').empty();
                var $alert = $('<div class="alert alert-' + type + ' alert-dismissible fade show" role="alert">' +
                    message + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button></div>');
                $('#alert-container').prepend($alert);
                setTimeout(function () { $alert.alert('close'); }, 3000);
            }

            // Xử lý submit form Lưu/Xóa khỏi thư viện
            $('.library-form').on('submit', function (e) {
                e.preventDefault(); // Ngăn submit mặc định

                var $form = $(this);
                var action = $form.data('action');
                var storyId = $form.data('story-id');
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '/Story/' + action,
                    type: 'POST',
                    data: {
                        storyId: storyId,
                        __RequestVerificationToken: token
                    },
                    success: function (response) {
                        if (response.success) {
                            // Cập nhật trạng thái nút
                            var newAction = action === 'AddToLibrary' ? 'RemoveFromLibrary' : 'AddToLibrary';
                            var newText = action === 'AddToLibrary' ? 'Xóa khỏi thư viện' : 'Lưu vào thư viện';
                            $form.data('action', newAction);
                            $form.find('.library-btn').text(newText);

                            // Cập nhật tất cả form trên trang
                            $('.library-form').each(function () {
                                $(this).data('action', newAction);
                                $(this).find('.library-btn').text(newText);
                            });

                            showAlert('success', response.message);
                        } else {
                            showAlert('danger', response.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        var errorMessage = xhr.responseJSON && xhr.responseJSON.message
                            ? xhr.responseJSON.message
                            : 'Có lỗi xảy ra khi thực hiện thao tác.';
                        showAlert('danger', errorMessage);
                    }
                });
            });

            // Hàm xử lý chuyển chương (dùng chung cho prev và next)
            function navigateChapter(chapterId, isNext) {
                console.log('Navigating chapter with ID:', chapterId, 'isNext:', isNext);
                $.ajax({
                    url: isNext ? '@Url.Action("NextChapterJson", "Segment")' : '@Url.Action("PrevChapterJson", "Segment")',
                    type: 'GET',
                    data: { currentChapterId: chapterId },
                    success: function (response) {
                        console.log('Navigate chapter response:', response);
                        if (response.success) {
                            updateSegment(response.data);
                        } else {
                            showAlert('warning', response.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        console.log('Navigate chapter error:', xhr, status, error);
                        var errorMessage = xhr.responseJSON && xhr.responseJSON.message
                            ? xhr.responseJSON.message
                            : 'Có lỗi xảy ra khi chuyển chương. Status: ' + xhr.status + ', Error: ' + (xhr.statusText || error);
                        showAlert('danger', errorMessage);
                    }
                });
            }

            // Xử lý nút "Chương trước"
            $(document).on('click', '.prev-chapter', function (e) {
                e.preventDefault();
                var chapterId = $(this).data('current-chapter-id');
                navigateChapter(chapterId, false);
            });

            // Xử lý nút "Chương sau"
            $(document).on('click', '.next-chapter', function (e) {
                e.preventDefault();
                var chapterId = $(this).data('current-chapter-id');
                navigateChapter(chapterId, true);
            });

            // Xử lý lựa chọn
            $(document).on('click', '.choice-button', function (e) {
                e.preventDefault();
                var choiceId = $(this).data('choice-id');
                var token = $('input[name="__RequestVerificationToken"]').val();
                console.log('Sending AJAX with choiceId:', choiceId, 'Token:', token);

                $.ajax({
                    url: '@Url.Action("ChooseJson", "Choice")',
                    type: 'POST',
                    contentType: 'application/x-www-form-urlencoded; charset=UTF-8',
                    data: $.param({
                        id: choiceId,
                        __RequestVerificationToken: token
                    }),
                    success: function (response) {
                        console.log('AJAX Success:', response);
                        if (response.success) {
                            updateSegment(response.data);
                        } else {
                            showAlert('danger', response.message);
                        }
                    },
                    error: function (xhr, status, error) {
                        console.log('AJAX Error:', { status: xhr.status, statusText: xhr.statusText, response: xhr.responseJSON, error: error });
                        var errorMessage = xhr.responseJSON && xhr.responseJSON.message
                            ? xhr.responseJSON.message
                            : 'Có lỗi xảy ra khi chọn lựa chọn. Status: ' + xhr.status + ', Error: ' + (xhr.statusText || error);
                        showAlert('danger', errorMessage);
                    }
                });
            });

            // Hàm cập nhật nội dung đoạn
            function updateSegment(data) {
                console.log('Updating segment with data:', data);
                if (!data || !data.chapterId) {
                    showAlert('danger', 'Không thể cập nhật nội dung: Dữ liệu chương không hợp lệ.');
                    return;
                }

                // Cập nhật tiêu đề truyện
                $('#chapter-header').html(`
                    <h3 class="story-title">${data.storyTitle}</h3>
                    <div class="author-info">
                        <img src="${data.authorAvatarUrl}" alt="Avatar" class="author-avatar" />
                        <a href="@Url.Action("Profile", "Account")/${data.authorId || ''}" title="Xem trang cá nhân">
                            ${data.authorUserName || 'Không xác định'}
                        </a>
                    </div>
                `);

                // Cập nhật tiêu đề chương
                $('#chapter-title').text(data.chapterTitle);

                // Cập nhật thời gian
                var metaHtml = `<p><span class="time-info">Thời gian đăng: ${data.createdAt}</span>`;
                if (data.updatedAt) {
                    metaHtml += `<span class="separator">|</span><span class="time-info">Thời gian chỉnh sửa: ${data.updatedAt}</span>`;
                }
                metaHtml += `</p>`;
                $('#chapter-meta').html(metaHtml);

                // Cập nhật nút điều hướng
                $('.prev-chapter').data('current-chapter-id', data.chapterId);
                $('.next-chapter').data('current-chapter-id', data.chapterId);

                // Cập nhật nội dung đoạn
                var contentHtml = '';
                if (data.imageUrl && data.imagePosition === 'Top') {
                    contentHtml += `
                        <div class="text-center mb-3">
                            <img src="${data.imageUrl}" class="img-fluid rounded shadow segment-image" alt="Ảnh minh họa" />
                        </div>`;
                }
                contentHtml += `<div id="segment-text">${data.content}</div>`;
                if (data.imageUrl && data.imagePosition === 'Bottom') {
                    contentHtml += `
                        <div class="text-center mb-3">
                            <img src="${data.imageUrl}" class="img-fluid rounded shadow segment-image" alt="Ảnh minh họa" />
                        </div>`;
                }
                $('#segment-content .card-body').html(contentHtml);

                // Cập nhật danh sách lựa chọn
                var choicesHtml = '';
                if (data.choices && data.choices.length > 0) {
                    choicesHtml = '<ul class="list-group mb-4">';
                    data.choices.forEach(function (choice) {
                        choicesHtml += `
                            <li class="list-group-item">
                                <button class="btn btn-outline-dark w-100 choice-button" data-choice-id="${choice.id}">
                                    ${choice.choiceText}
                                </button>
                            </li>`;
                    });
                    choicesHtml += '</ul>';
                } else {
                    choicesHtml = '<p class="text-muted">Không có lựa chọn nào khả dụng cho đoạn này.</p>';
                }
                $('#choices-container').html(choicesHtml);

                // Cập nhật trạng thái thư viện
                var libraryAction = data.isInLibrary ? 'RemoveFromLibrary' : 'AddToLibrary';
                var libraryText = data.isInLibrary ? 'Xóa khỏi thư viện' : 'Lưu vào thư viện';
                $('.library-form').each(function () {
                    $(this).data('action', libraryAction);
                    $(this).find('.library-btn').text(libraryText);
                });

                // Cuộn lên đầu trang
                window.scrollTo(0, 0);
            }
        });
    </script>
}