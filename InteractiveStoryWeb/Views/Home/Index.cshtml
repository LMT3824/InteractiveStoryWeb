@model InteractiveStoryWeb.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<h2 class="mb-4">🔥 Truyện nổi bật</h2>
<div class="row row-cols-2 row-cols-md-4 g-4 mb-5">
    @foreach (var story in Model.TopViewed)
    {
        <div class="col">
            <a asp-controller="Story" asp-action="Details" asp-route-id="@story.Id" class="text-decoration-none text-dark">
                <div class="card h-100">
                    <img src="@(!string.IsNullOrEmpty(story.CoverImageUrl) ? story.CoverImageUrl : "/images/ImageNotFound.png")"
                         class="card-img-top" style="height:200px; object-fit:cover;" />
                    <div class="card-body">
                        <h5 class="card-title">@story.Title</h5>
                        <p class="card-text text-muted">@ViewBag.ViewCounts[story.Id] lượt xem</p>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

<h2 class="mb-4">🆕 Truyện mới</h2>
<div class="row row-cols-2 row-cols-md-4 g-4 mb-5">
    @foreach (var story in Model.NewStories)
    {
        <div class="col">
            <a asp-controller="Story" asp-action="Details" asp-route-id="@story.Id" class="text-decoration-none text-dark">
                <div class="card h-100">
                    <img src="@(!string.IsNullOrEmpty(story.CoverImageUrl) ? story.CoverImageUrl : "/images/ImageNotFound.png")"
                         class="card-img-top" style="height:200px; object-fit:cover;" />
                    <div class="card-body">
                        <h5 class="card-title">@story.Title</h5>
                        <p class="card-text text-muted">Ngày đăng: @story.CreatedAt.ToString("dd/MM/yyyy")</p>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

<h2 class="mb-4">✅ Truyện đã hoàn thành</h2>
<div class="row row-cols-2 row-cols-md-4 g-4 mb-5">
    @foreach (var story in Model.CompletedStories)
    {
        <div class="col">
            <a asp-controller="Story" asp-action="Details" asp-route-id="@story.Id" class="text-decoration-none text-dark">
                <div class="card h-100">
                    <img src="@(!string.IsNullOrEmpty(story.CoverImageUrl) ? story.CoverImageUrl : "/images/ImageNotFound.png")"
                         class="card-img-top" style="height:200px; object-fit:cover;" />
                    <div class="card-body">
                        <h5 class="card-title">@story.Title</h5>
                        <p class="card-text text-muted">Đã hoàn thành</p>
                    </div>
                </div>
            </a>
        </div>
    }
</div>