@model InteractiveStoryWeb.ViewModels.ChoiceCreateViewModel
@{
    ViewData["Title"] = "Quản lý lựa chọn";
    var segment = ViewBag.Segment as InteractiveStoryWeb.Models.ChapterSegment;
    var availableSegments = ViewBag.AvailableSegments as List<InteractiveStoryWeb.Models.ChapterSegment>;
    var storyId = ViewBag.StoryId;
}

<h2 class="mb-4">🔗 Quản lý lựa chọn cho đoạn ID: @segment.Id</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="alert alert-light mb-3">
    <strong>Nội dung đoạn:</strong> @(segment.Content?.Length > 80 ? segment.Content.Substring(0, 80) + "..." : segment.Content)
</div>

@if (segment.Choices != null && segment.Choices.Any())
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Lựa chọn</th>
                <th>Đi tới đoạn</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in segment.Choices)
            {
                <tr>
                    <td>@c.ChoiceText</td>
                    <td>@(c.NextSegment?.Title ?? $"ID: {c.NextSegmentId}")</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-warning">
                            <i class="bi bi-pencil"></i> Sửa
                        </a>
                        <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-danger ms-2"
                           onclick="return confirm('Bạn có chắc chắn muốn xóa lựa chọn này?');">
                            <i class="bi bi-trash"></i> Xóa
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Chưa có lựa chọn nào.</p>
}

<hr />
<h4>➕ Thêm lựa chọn mới</h4>

<form asp-action="Add" method="post">
    <input type="hidden" asp-for="ChapterSegmentId" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="ChoiceText" class="form-label">Nội dung lựa chọn</label>
        <input asp-for="ChoiceText" class="form-control" placeholder="Nhập nội dung lựa chọn..." />
        <span asp-validation-for="ChoiceText" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="NextSegmentId" class="form-label">Đoạn tiếp theo</label>
        <select asp-for="NextSegmentId" class="form-select" asp-items="@(new SelectList(availableSegments, "Id", "Title"))">
            <option value="">-- Chọn đoạn --</option>
        </select>
        <span asp-validation-for="NextSegmentId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">➕ Thêm lựa chọn</button>
    <a asp-controller="Chapter" asp-action="Manage" asp-route-storyId="@storyId" class="btn btn-secondary ms-2">⬅️ Quay lại</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}