@model List<InteractiveStoryWeb.Models.ApplicationUser>
@{
    ViewData["Title"] = "Người theo dõi";
    var targetUser = ViewBag.TargetUser as InteractiveStoryWeb.Models.ApplicationUser;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

    .page-header .back-arrow {
        cursor: pointer;
        color: #000;
        text-decoration: none;
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        vertical-align: middle;
    }

    .page-header .back-arrow svg {
        width: 100%;
        height: 100%;
    }

    .page-header h2 {
        font-family: 'STIX Two Text', serif;
        font-weight: 700;
        font-size: 32px;
        margin-top: 26px;
        margin-bottom: 20px;
        line-height: 30px;
    }

    /* Định dạng cho khung người theo dõi */
    .follower-card {
        background-color: #fff;
        border-radius: 10px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        height: 280px; /* Tăng chiều cao khung */
        display: flex;
        flex-direction: column;
        user-select: none; /* Ngăn chọn */
    }

    .follower-card-upper {
        background-color: #FFDAB7;
        height: 40%; /* Chiếm 1/3 khung */
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px;
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
    }

    .follower-card-lower {
        background-color: #fff;
        flex-grow: 1;
        padding: 10px;
        border-bottom-left-radius: 10px;
        border-bottom-right-radius: 10px;
        display: flex;
        align-items: top;
        justify-content: center;
    }

    .follower-card-upper .avatar-container {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .follower-card-upper img {
        width: 70px;
        height: 70px;
        object-fit: cover;
        border-radius: 50%;
    }

    .follower-card-upper .username {
        font-size: 20px;
        font-weight: 400;
        text-decoration: none;
        color: #000;
    }

    .follower-card-upper .username:hover {
        text-decoration: underline; /* Thêm gạch chân khi hover */
    }

    .follower-card-upper .follow-btn {
        background-color: #5B2A00;
        color: #fff;
        border: none;
        padding: 5px 10px;
        font-size: 17px;
        border-radius: 5px;
        cursor: pointer;
        user-select: none; /* Ngăn chọn */
    }

    .follower-card-lower .caption {
        background-color: #fff;
        padding: 10px;
        display: flex;
        align-items: left;
        justify-content: left;
        text-align: left;
        color: #000;
        font-size: 17px;
        width: 100%;
        user-select: none; /* Ngăn chọn */
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=STIX+Two+Text&display=swap" rel="stylesheet">

<div class="page-header">
    <a href="javascript:history.back()" class="back-arrow">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
    </a>
    <h2>NGƯỜI THEO DÕI | @targetUser.UserName</h2>
</div>

@if (Model != null && Model.Any())
{
    <div class="row row-cols-1 row-cols-md-4 g-4">
        @foreach (var user in Model)
        {
            bool isFollowing = ViewBag.IsFollowing != null && ViewBag.IsFollowing.GetType() == typeof(Dictionary<string, bool>)
                ? ((Dictionary<string, bool>)ViewBag.IsFollowing).ContainsKey(user.Id) && ((Dictionary<string, bool>)ViewBag.IsFollowing)[user.Id]
                : false;

            <div class="col">
                <div class="follower-card">
                    <div class="follower-card-upper">
                        <div class="avatar-container">
                            <img src="@(string.IsNullOrEmpty(user.AvatarUrl) ? Url.Content("~/images/AvatarNull.jpg") : user.AvatarUrl)" alt="Avatar" />
                            <a href="@Url.Action("MyProfile", new { userId = user.Id })" class="username">@user.UserName</a>
                        </div>
                        @if (user.Id != currentUserId)
                        {
                            <button class="follow-btn @(isFollowing ? "btn-danger" : "btn-success")"
                                    data-user-id="@user.Id"
                                    data-is-following="@isFollowing.ToString().ToLower()">
                                @(isFollowing ? "Hủy theo dõi" : "Theo dõi")
                            </button>
                        }
                    </div>
                    <div class="follower-card-lower">
                        <p class="caption">@(string.IsNullOrEmpty(user.Caption) ? "Chưa có giới thiệu" : user.Caption)</p>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info mt-3">
        @(targetUser.UserName) chưa có người theo dõi.
    </div>
}

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.follow-btn').click(function () {
                var button = $(this);
                var userId = button.data('user-id');
                var isFollowing = button.data('is-following') === true;
                var url = isFollowing ? '@Url.Action("UnfollowUser", "Account")' : '@Url.Action("FollowUser", "Account")';

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: { targetUserId: userId },
                    headers: {
                        'X-CSRF-TOKEN': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            button.text(isFollowing ? 'Theo dõi' : 'Hủy theo dõi');
                            button.toggleClass('btn-success btn-danger');
                            button.data('is-following', !isFollowing);
                            if (response.followersCount !== undefined) {
                                // Có thể thêm logic để cập nhật số liệu followers trên giao diện
                            }
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function () {
                        alert('Có lỗi xảy ra. Vui lòng thử lại.');
                    }
                });
            });
        });
    </script>
}