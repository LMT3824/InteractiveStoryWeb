@model InteractiveStoryWeb.Models.Chapter

@{
    ViewData["Title"] = "Đọc truyện";
}

<h2 class="mb-3">@Model.Story.Title</h2>

@if (!string.IsNullOrEmpty(Model.ImageUrl))
{
    <div class="text-center mb-4">
        <img src="@Model.ImageUrl" alt="Ảnh minh họa" class="img-fluid" style="max-height: 400px;" />
    </div>
}

<div class="card p-3 mb-4">
    <p>@Html.Raw(Model.Content)</p>
</div>

@if (Model.Choices != null && Model.Choices.Any())
{
    <h5>Lựa chọn của bạn:</h5>
    <div class="d-flex flex-column gap-2">
        @foreach (var choice in Model.Choices)
        {
            <a class="btn btn-outline-primary"
               asp-controller="Chapter"
               asp-action="Read"
               asp-route-id="@choice.NextChapterId">
                @choice.ChoiceText
            </a>
        }
    </div>
}
else
{
    <div class="alert alert-info mt-4">
        Không có lựa chọn nào. Đây có thể là chương cuối hoặc tác giả chưa viết tiếp.
    </div>
}
