@model InteractiveStoryWeb.Models.Chapter
@{
    ViewData["Title"] = "Chỉnh sửa chương truyện";
}

<h2 class="mb-4">📝 @ViewData["Title"]</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="StoryId" />

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label">Tiêu đề chương</label>
        <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề chương..." />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsPublic" class="form-check-input" />
        <label asp-for="IsPublic" class="form-check-label">Công khai chương này</label>
    </div>

    <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
    <a asp-action="Manage" asp-route-storyId="@Model.StoryId" class="btn btn-secondary ms-2">⬅️ Quay lại</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}