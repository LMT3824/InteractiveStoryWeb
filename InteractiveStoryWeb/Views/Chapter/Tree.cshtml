@model List<InteractiveStoryWeb.Models.Chapter>
@{
    ViewData["Title"] = "Sơ đồ chương";
    int storyId = (int)ViewBag.StoryId;
}

<h2 class="mb-4">🌳 Danh sách chương của truyện</h2>

<ul class="list-group">
    @foreach (var chapter in Model)
    {
        <li class="list-group-item d-flex justify-content-between">
            <span>📘 <strong>@chapter.Title</strong> (ID: @chapter.Id)</span>
            <span>
                <a asp-controller="Chapter" asp-action="Read" asp-route-id="@chapter.Id" class="btn btn-sm btn-outline-primary">📖 Đọc chương</a>
                <a asp-controller="Segment" asp-action="Create" asp-route-chapterId="@chapter.Id" class="btn btn-sm btn-outline-success ms-1">➕ Thêm đoạn</a>
            </span>
        </li>
    }
</ul>
