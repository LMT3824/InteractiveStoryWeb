@model List<InteractiveStoryWeb.Models.Chapter>
@using InteractiveStoryWeb.ViewModels
@{
    ViewData["Title"] = "Quản lý chương & phân nhánh của truyện";
    var storyId = ViewBag.StoryId;
}

<h2 class="mb-4"><i class="bi bi-journal-bookmark"></i> Quản lý chương & phân nhánh của truyện</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0">Thêm chương mới</h5>
    </div>
    <div class="card-body">
        <form asp-controller="Chapter" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="StoryId" value="@storyId" />
            <div class="row g-3">
                <div class="col-md-9">
                    <label class="form-label">Tiêu đề chương</label>
                    <input name="Title" class="form-control" placeholder="Nhập tiêu đề chương..." required />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100 mt-4">Thêm chương</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        Truyện này chưa có chương nào.
    </div>
}
else
{
    foreach (var chapter in Model.OrderBy(c => c.CreatedAt))
    {
        <div class="card mb-3 border-primary">
            <div class="card-header bg-primary text-white fw-bold">
                <i class="bi bi-journal-text"></i> Chương @chapter.Title (ID: @chapter.Id)
                <span class="badge @(chapter.IsPublic ? "bg-success" : "bg-secondary") ms-2">
                    @(chapter.IsPublic ? "Công khai" : "Không công khai")
                </span>
                <span class="badge bg-info ms-2">
                    <i class="bi bi-eye"></i> @chapter.ViewCount lượt xem
                </span>

                <div class="float-end">
                    <button type="button" class="btn btn-warning btn-sm toggle-edit-form" data-chapter-id="@chapter.Id">
                        <i class="bi bi-pencil"></i> Sửa
                    </button>
                    <form asp-controller="Chapter" asp-action="Delete" asp-route-id="@chapter.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm ms-2" onclick="return confirm('Bạn có chắc chắn muốn xóa chương này?');">
                            <i class="bi bi-trash"></i> Xóa
                        </button>
                    </form>
                </div>
            </div>
            <div class="card-body">
                <!-- Form chỉnh sửa chương -->
                <div class="edit-chapter-form" id="edit-chapter-@chapter.Id" style="display: none;">
                    <form asp-controller="Chapter" asp-action="Edit" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Id" value="@chapter.Id" />
                        <input type="hidden" name="StoryId" value="@chapter.StoryId" />
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Tiêu đề chương</label>
                                <input name="Title" class="form-control" value="@chapter.Title" required />
                            </div>
                            <div class="col-md-3">
                                <div class="form-check mt-4">
                                    <input name="IsPublic" type="checkbox" class="form-check-input" value="true" @(chapter.IsPublic ? "checked" : "") />
                                    <label class="form-check-label">Công khai chương này</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <button type="submit" class="btn btn-primary w-100 mt-4">Lưu</button>
                            </div>
                        </div>
                    </form>
                </div>

                <a class="btn btn-outline-success mb-2"
                   asp-controller="Segment" asp-action="Create" asp-route-chapterId="@chapter.Id">
                    <i class="bi bi-plus-circle"></i> Thêm đoạn mới
                </a>

                @if (chapter.Segments != null && chapter.Segments.Any())
                {
                    foreach (var segment in chapter.Segments.OrderBy(s => s.Id))
                    {
                        <div class="card mb-2 border-light">
                            <div class="card-header">
                                <strong>Đoạn @segment.Title</strong> (ID: @segment.Id)

                                <div class="float-end">
                                    <a asp-controller="Segment" asp-action="Edit" asp-route-id="@segment.Id"
                                       class="btn btn-sm btn-warning ms-2">
                                        <i class="bi bi-pencil"></i> Sửa
                                    </a>
                                    <form asp-controller="Segment" asp-action="Delete" asp-route-id="@segment.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger ms-2" onclick="return confirm('Bạn có chắc chắn muốn xóa đoạn này?');">
                                            <i class="bi bi-trash"></i> Xóa
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <div class="card-body">
                                <p>@(segment.Content?.Length > 80 ? segment.Content.Substring(0, 80) + "..." : segment.Content)</p>

                                <!-- Form thêm lựa chọn -->
                                <form asp-controller="Choice" asp-action="Add" method="post" class="row g-2 mt-3">
                                    <input type="hidden" name="ChapterSegmentId" value="@segment.Id" />
                                    <div class="col-md-5">
                                        <input name="ChoiceText" class="form-control" placeholder="Nội dung lựa chọn" required />
                                    </div>
                                    <div class="col-md-5">
                                        <select name="NextSegmentId" class="form-select" required>
                                            <option value="">-- Chọn đoạn tiếp theo --</option>
                                            @foreach (var target in chapter.Segments)
                                            {
                                                <option value="@target.Id">@target.Title</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-2">
                                        <button type="submit" class="btn btn-success w-100">Thêm lựa chọn</button>
                                    </div>
                                </form>
                                <!-- Danh sách các lựa chọn -->
                                @if (segment.Choices != null && segment.Choices.Any())
                                {
                                    <ul class="list-group">
                                        @foreach (var choice in segment.Choices)
                                        {
                                            <li class="list-group-item d-flex justify-content-between align-items-center choice-item" data-choice-id="@choice.Id">
                                                <div class="choice-display">
                                                    <span class="choice-text">@choice.ChoiceText</span>
                                                    <span class="badge bg-dark ms-2">→ Đến đoạn: @(choice.NextSegment != null ? choice.NextSegment.Title : "Không xác định")</span>
                                                </div>
                                                <div class="choice-edit" style="display: none;">
                                                    <input type="hidden" class="edit-choice-id" value="@choice.Id" />
                                                    <input type="hidden" class="edit-chapter-segment-id" value="@choice.ChapterSegmentId" />
                                                    <input type="hidden" class="edit-created-at" value="@choice.CreatedAt.ToString("o")" />
                                                    <input type="text" class="form-control edit-choice-text" value="@choice.ChoiceText" style="display: inline-block; width: 200px;" required />
                                                    <select class="form-select edit-next-segment-id" style="display: inline-block; width: 200px;" required data-original-value="@choice.NextSegmentId">
                                                        <option value="">-- Chọn đoạn --</option>
                                                        @foreach (var target in chapter.Segments)
                                                        {
                                                            @if (target.Id == choice.NextSegmentId)
                                                            {
                                                                <option value="@target.Id" selected>@target.Title</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@target.Id">@target.Title</option>
                                                            }
                                                        }
                                                    </select>
                                                    <button type="button" class="btn btn-success btn-sm save-choice-btn ms-2">Lưu</button>
                                                    <button type="button" class="btn btn-secondary btn-sm cancel-choice-btn ms-2">Hủy</button>
                                                </div>
                                                <div class="choice-actions">
                                                    <button type="button" class="btn btn-warning btn-sm edit-choice-btn ms-2">
                                                        <i class="bi bi-pencil"></i> Sửa
                                                    </button>
                                                    <a asp-controller="Choice" asp-action="Delete" asp-route-id="@choice.Id" class="btn btn-danger btn-sm ms-2" onclick="return confirm('Bạn có chắc chắn muốn xóa lựa chọn này?');">
                                                        <i class="bi bi-trash"></i> Xóa
                                                    </a>
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <div class="alert alert-light mt-2">Không có lựa chọn nào cho đoạn này.</div>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-light">Chương này chưa có đoạn nào.</div>
                }
            </div>
        </div>
    }
}

<style>
    .choice-text {
        overflow-wrap: break-word;
        max-width: 100%;
        display: inline-block;
    }

    .list-group-item {
        word-break: break-word;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Toggle form chỉnh sửa chương
            $('.toggle-edit-form').on('click', function () {
                var chapterId = $(this).data('chapter-id');
                $('#edit-chapter-' + chapterId).toggle();
            });

            // Xử lý chỉnh sửa lựa chọn
            $('.edit-choice-btn').on('click', function () {
                var $row = $(this).closest('.choice-item');
                $row.find('.choice-display').hide();
                $row.find('.choice-actions').hide();
                $row.find('.choice-edit').show();
            });

            $('.cancel-choice-btn').on('click', function () {
                var $row = $(this).closest('.choice-item');
                $row.find('.choice-display').show();
                $row.find('.choice-actions').show();
                $row.find('.choice-edit').hide();

                var $textInput = $row.find('.edit-choice-text');
                var originalText = $textInput.data('original-value');
                $textInput.val(originalText);

                var $selectInput = $row.find('.edit-next-segment-id');
                var originalNextSegmentId = $selectInput.attr('data-original-value');
                $selectInput.val(originalNextSegmentId);
            });

            $('.save-choice-btn').on('click', function () {
                var $row = $(this).closest('.choice-item');
                var choiceId = $row.find('.edit-choice-id').val();
                var chapterSegmentId = $row.find('.edit-chapter-segment-id').val();
                var createdAt = $row.find('.edit-created-at').val();
                var choiceText = $row.find('.edit-choice-text').val();
                var nextSegmentId = $row.find('.edit-next-segment-id').val();

                if (!choiceText || !nextSegmentId) {
                    alert('Vui lòng điền đầy đủ thông tin.');
                    return;
                }

                $.ajax({
                    url: '/Choice/Edit',
                    type: 'POST',
                    data: {
                        Id: choiceId,
                        ChapterSegmentId: chapterSegmentId,
                        CreatedAt: createdAt,
                        ChoiceText: choiceText,
                        NextSegmentId: nextSegmentId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            $row.find('.choice-text').text(response.choiceText);
                            $row.find('.badge').text('→ Đến đoạn: ' + response.nextSegmentTitle);
                            $row.find('.choice-display').show();
                            $row.find('.choice-actions').show();
                            $row.find('.choice-edit').hide();
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function () {
                        alert('Có lỗi xảy ra khi lưu thay đổi.');
                    }
                });
            });

            $('.choice-item').each(function () {
                var $row = $(this);
                $row.find('.edit-choice-text').data('original-value', $row.find('.choice-text').text().trim());
                $row.find('.edit-next-segment-id').data('original-value', $row.find('.edit-next-segment-id').attr('data-original-value'));
            });
        });
    </script>
}