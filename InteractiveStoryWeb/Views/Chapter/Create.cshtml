@model InteractiveStoryWeb.ViewModels.ChapterCreateViewModel

@{
    ViewData["Title"] = "Tạo chương mới";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="StoryId" />
    <input type="hidden" asp-for="ParentChapterId" />

    <div class="form-group mb-3">
        <label asp-for="Content" class="form-label"></label>
        <textarea asp-for="Content" class="form-control" rows="6"></textarea>
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Image" class="form-label"></label>
        <input asp-for="Image" type="file" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">Lưu chương</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
