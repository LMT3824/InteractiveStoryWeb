@model InteractiveStoryWeb.Models.Story
@{
    ViewData["Title"] = "Chỉnh sửa truyện";
}

<h2 class="mb-4">@ViewData["Title"]</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="AuthorId" />
    <input type="hidden" asp-for="CreatedAt" />

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="Title" class="form-label">Tiêu đề truyện</label>
        <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề truyện..." />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Genre" class="form-label">Thể loại</label>
        <select asp-for="Genre" class="form-select" asp-items="@(new SelectList(ViewBag.Genres, "Name", "Name"))">
            <option value="">-- Chọn thể loại --</option>
        </select>
        <span asp-validation-for="Genre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Mô tả truyện</label>
        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Nhập mô tả truyện..."></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="IsPublic" class="form-check-label">Công khai?</label>
        <input asp-for="IsPublic" class="form-check-input ms-2" type="checkbox" />
    </div>

    <div class="mb-3">
        <label for="NewCoverImage" class="form-label">Ảnh bìa mới (tuỳ chọn)</label>
        <input type="file" name="NewCoverImage" class="form-control" accept="image/*" />
        <small class="form-text text-muted">Chọn ảnh bìa mới (định dạng: jpg, png, ...)</small>
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <div class="mt-2">
                <p>Ảnh hiện tại:</p>
                <img src="@Model.CoverImageUrl" class="img-thumbnail" style="max-height: 200px;" />
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary ms-2">⬅️ Quay lại</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}