@model InteractiveStoryWeb.ViewModels.StoryCreateViewModel

@{
    ViewData["Title"] = "Chỉnh sửa truyện";
}

<style>
    /* Đưa số ký tự vào trong textarea */
    .textarea-wrapper {
        position: relative;
        width: 100%; /* Chiều rộng của textarea */
        margin: 0 auto;
    }

        .textarea-wrapper textarea {
            padding-bottom: 30px; /* Tạo khoảng trống cho số ký tự ở dưới */
        }

        .textarea-wrapper .char-counter {
            position: absolute;
            bottom: 10px;
            right: 10px;
            color: #666;
            font-size: 14px;
            background: rgba(255, 255, 255, 0.8); /* Nền mờ để dễ đọc */
            padding: 2px 5px;
            border-radius: 3px;
        }

    /* Khung ảnh bìa */
    .cover-image-preview {
        width: 210px;
        height: 280px;
        border: 1px solid #e0e0e0;
        border-radius: 5px;
        overflow: hidden;
        margin-top: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f8f9fa;
    }

        .cover-image-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
</style>

<h2 class="mb-4">@ViewData["Title"]</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="Edit" enctype="multipart/form-data" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Title" class="form-label">Tiêu đề truyện</label>
        <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề truyện..." />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Genre" class="form-label">Thể loại</label>
        <select asp-for="Genre" class="form-select" asp-items="@(new SelectList(ViewBag.Genres, "Name", "Name"))">
            <option value="">-- Chọn thể loại --</option>
        </select>
        <span asp-validation-for="Genre" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Mô tả truyện</label>
        <div class="textarea-wrapper">
            <textarea asp-for="Description" class="form-control" id="DescriptionEdit" rows="5" placeholder="Nhập mô tả truyện..." maxlength="1000"></textarea>
            <span class="char-counter" id="charCounterEdit">0/1000</span>
        </div>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="NewCoverImage" class="form-label">Ảnh bìa mới (tuỳ chọn)</label>
        <input type="file" name="NewCoverImage" id="coverImageInput" class="form-control" accept="image/*" />
        <small class="form-text text-muted">Chọn ảnh bìa mới (định dạng: jpg, png, ...)</small>
        <small class="form-text text-muted">Lưu ý: hãy dùng ảnh có định dạng 210x280 để có được chất lượng tốt nhất.</small>
        <div class="cover-image-preview">
            <img src="@(string.IsNullOrEmpty(ViewBag.CoverImageUrl) ? "/images/ImageNotFound.png" : ViewBag.CoverImageUrl)" id="coverImagePreview" alt="Ảnh bìa truyện" />
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="IsPublic" class="form-check-label">Công khai truyện</label>
        <input asp-for="IsPublic" class="form-check-input ms-2" type="checkbox" />
        <small class="form-text text-muted">
            Truyện sẽ không được công khai nếu không có ít nhất một chương công khai và chứa ít nhất một đoạn.
        </small>
    </div>

    <div class="mb-3">
        <label asp-for="AllowCustomization" class="form-check-label">Cho phép người đọc tùy chỉnh tên và xưng hô</label>
        <input asp-for="AllowCustomization" class="form-check-input ms-2" type="checkbox" />
    </div>

    <div class="mb-3">
        <label asp-for="IsCompleted" class="form-check-label">Truyện đã hoàn thành</label>
        <input asp-for="IsCompleted" class="form-check-input ms-2" type="checkbox" />
    </div>

    <button type="submit" class="btn btn-primary">💾 Lưu thay đổi</button>
    <a asp-controller="Account" asp-action="MyProfile" class="btn btn-secondary ms-2">⬅️ Quay lại</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            // Cập nhật số ký tự trong textarea
            function updateCharCounter() {
                var descriptionLength = $('#DescriptionEdit').val().length;
                $('#charCounterEdit').text(descriptionLength + '/1000');
            }

            // Lắng nghe sự kiện input trên textarea
            $('#DescriptionEdit').on('input', function () {
                updateCharCounter();
            });

            // Cập nhật số ký tự ngay khi tải trang
            updateCharCounter();

            // Hiển thị ảnh bìa ngay khi chọn file (thêm đoạn này)
            $('#coverImageInput').on('change', function (e) {
                var file = e.target.files[0];
                if (file && file.type.startsWith('image/')) {
                    var reader = new FileReader();
                    reader.onload = function (e) {
                        $('#coverImagePreview').attr('src', e.target.result);
                    };
                    reader.readAsDataURL(file);
                } else {
                    $('#coverImagePreview').attr('src', '@(string.IsNullOrEmpty(ViewBag.CoverImageUrl) ? "/images/ImageNotFound.png" : ViewBag.CoverImageUrl)');
                }
            });
        });
    </script>
}