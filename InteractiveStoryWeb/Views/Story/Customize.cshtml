@model InteractiveStoryWeb.ViewModels.StoryCustomizationViewModel

@{
    ViewData["Title"] = "Tùy chỉnh nhân vật";
}

<style>
    /* Khung chính căn đều với header trang */
    .main-container {
        max-width: 1600px;
        margin: 0 auto; /* Căn giữa khung */
    }

    /* Khung form tùy chỉnh */
    .customize-container {
        max-width: 1300px; /* Điều chỉnh chiều rộng thành 1400px */
        margin: 0 auto; /* Căn giữa khung */
        margin-top: 24px;
        padding: 24px;
        background: #FFF7EF; /* Nền màu be nhạt */
        border: 2px solid #BCAA98; /* Viền màu nâu nhạt */
        border-radius: 8px; /* Bo góc */
    }

    /* Header bên trong form */
    .customize-header {
        display: flex;
        justify-content: space-between; /* Tiêu đề trái, nút phải */
        align-items: center;
        margin-bottom: 24px;
    }

    .customize-header-left {
        display: flex;
        align-items: center;
    }

    /* Nút quay lại */
    .back-button {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 4px;
        text-decoration: none; /* Bỏ gạch chân */
        color: #000000;
        transition: background .2s;
        margin-right: 12px;
    }

        .back-button:hover {
            background: rgba(122,75,22,0.1);
            color: #000000;
        }

        .back-button svg {
            width: 100%;
            height: 100%;
        }

    /* Tiêu đề form */
    .customize-header h2 {
        font-family: 'STIX Two Text', serif;
        font-weight: 700;
        font-size: 32px;
        margin-top: 26px;
        margin-bottom: 20px;
        line-height: 30px;
    }

    /* Nút lưu và đọc ở trên cùng */
    .btn-submit-top {
        background-color: #5B2A00; /* Màu nâu đậm */
        color: #FFF;
        border: none;
        padding: 8px 20px;
        border-radius: 4px;
        font-size: 20px;
        font-weight: 500;
    }

        .btn-submit-top:hover {
            background-color: #4a2300;
        }

    /* Label và ô input */
    .form-label {
        display: block;
        margin-bottom: 6px;
        font-size: 20px;
        font-weight: 500;
        color: #000;
    }

    .form-group small {
        display: block;
        font-size: 18px;
        color: #7A6A5A;
        margin-top: 4px;
    }

    .form-control {
        width: 100%;
        border: 1px solid #999999;
        border-radius: 4px;
        background: #FFF;
        font-size: 18px;
        color: #333;
    }

        .form-control:focus {
            outline: none;
            border-color: #C4A484;
        }

    /* Preview section */
    .preview-section h5 {
        font-family: 'STIX Two Text', serif;
        display: block;
        margin-bottom: 6px;
        font-size: 23px;
        font-weight: 700;
        color: #000;
    }

    .preview-block {
        margin-bottom: 20px;
    }

        .preview-block h6 {
            display: block;
            margin-bottom: 6px;
            font-size: 20px;
            font-weight: 500;
            color: #000;
        }

    .preview-content {
        padding: 10px;
        border: 1px solid #999999;
        border-radius: 5px;
        background-color: #FFFFFF;
    }

        .preview-content p {
            margin: 5px 0;
            font-size: 18px;
            line-height: 1.8;
            color: #000;
        }

        .preview-content .placeholder {
            color: #000;
            font-family: 'Itim', cursive;
        }

    /* Kiểu cho link Tìm hiểu thêm */
    .learn-more-link {
        font-size: 18px;
        color: #5B2A00;
        text-decoration: none;
        transition: text-decoration 0.2s;
        display: inline-block;
