@model InteractiveStoryWeb.Models.Story
@{
    ViewData["Title"] = Model.Title;
}

<div class="row">
    <div class="col-md-4">
        <img src="@(string.IsNullOrEmpty(Model.CoverImageUrl)
            ? Url.Content("~/images/ImageNotFound.png")
            : Model.CoverImageUrl)"
             class="img-fluid rounded shadow" alt="Ảnh bìa truyện" />
    </div>
    <div class="col-md-8">
        <h2>@Model.Title</h2>
        <p><strong>Thể loại:</strong> @Model.Genre</p>
        <p><strong>Mô tả:</strong> @Model.Description</p>
        <p><strong>Lượt xem:</strong> @ViewBag.TotalViewCount</p>
        <p><strong>Tác giả:</strong> @Model.Author?.UserName</p>
        <p><strong>Ngày đăng:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy")</p>
        <p><strong>Tùy chỉnh nhân vật:</strong> @(Model.AllowCustomization ? "Có" : "Không")</p>

        @if (ViewBag.FirstSegmentId != null)
        {
            <a asp-controller="Story" asp-action="Read" asp-route-id="@Model.Id"
               class="btn btn-primary">
                📖 Đọc truyện tương tác
            </a>
        }
        else
        {
            <div class="alert alert-warning mt-3">
                Truyện chưa có nội dung để đọc.
            </div>
        }

        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-secondary mt-2">✏️ Chỉnh sửa</a>
        <a asp-action="Index" class="btn btn-outline-secondary mt-2">⬅️ Quay lại</a>
    </div>
</div>