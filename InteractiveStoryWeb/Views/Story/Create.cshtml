@model InteractiveStoryWeb.ViewModels.StoryCreateViewModel

@{
    ViewData["Title"] = "Đăng truyện mới";
}

<h2 class="mb-4">@ViewData["Title"]</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="Create" enctype="multipart/form-data" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="form-group mb-3">
        <label asp-for="Title" class="form-label">Tiêu đề truyện</label>
        <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề truyện..." />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Genre" class="form-label">Thể loại</label>
        <select asp-for="Genre" class="form-select" asp-items="@(new SelectList(ViewBag.Genres, "Name", "Name"))">
            <option value="">-- Chọn thể loại --</option>
        </select>
        <span asp-validation-for="Genre" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="Description" class="form-label">Mô tả truyện</label>
        <textarea asp-for="Description" class="form-control" rows="5" placeholder="Nhập mô tả truyện..."></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="CoverImage" class="form-label">Ảnh bìa</label>
        <input asp-for="CoverImage" type="file" class="form-control" accept="image/*" />
        <small class="form-text text-muted">Chọn ảnh bìa (định dạng: jpg, png, ...)</small>
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsPublic" class="form-check-input" />
        <label asp-for="IsPublic" class="form-check-label">Công khai truyện</label>
    </div>

    <div class="form-check mb-3">
        <input asp-for="AllowCustomization" class="form-check-input" />
        <label asp-for="AllowCustomization" class="form-check-label">Cho phép người đọc tùy chỉnh tên và xưng hô</label>
    </div>

    <button type="submit" class="btn btn-primary">📖 Đăng truyện</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">⬅️ Quay lại</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}