@model IEnumerable<InteractiveStoryWeb.Models.Story>
@{
    ViewData["Title"] = "Danh sách truyện";
}

<h2 class="mb-4">@ViewData["Title"]</h2>

@if (User.Identity.IsAuthenticated)
{
    <div class="mb-4">
        <a asp-action="Create" class="btn btn-success">📖 Đăng truyện mới</a>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        Hiện tại chưa có truyện nào được công khai.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var story in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="@(string.IsNullOrEmpty(story.CoverImageUrl)
                        ? Url.Content("~/images/ImageNotFound.png")
                        : story.CoverImageUrl)"
                         class="card-img-top" style="height: 200px; object-fit: cover;" alt="Ảnh bìa truyện" />
                    <div class="card-body">
                        <h5 class="card-title">@story.Title</h5>
                        <p class="card-text"><strong>Thể loại:</strong> @story.Genre</p>
                        <p class="card-text"><strong>Mô tả:</strong> @(story.Description.Length > 100 ? story.Description.Substring(0, 100) + "..." : story.Description)</p>
                        <p class="card-text"><strong>Lượt xem:</strong> @ViewBag.ViewCounts[story.Id]</p> <!-- Sử dụng ViewBag -->
                        <p class="card-text"><small class="text-muted">Tác giả: @story.Author?.UserName</small></p>
                        <p class="card-text"><small class="text-muted">Ngày đăng: @story.CreatedAt.ToString("dd/MM/yyyy")</small></p>
                    </div>
                    <div class="card-footer bg-white border-top-0">
                        <a asp-action="Details" asp-route-id="@story.Id" class="btn btn-primary w-100">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        }
    </div>
}