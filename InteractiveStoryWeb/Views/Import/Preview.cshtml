@model InteractiveStoryWeb.ViewModels.ImportPreviewViewModel

@{
    ViewData["Title"] = "Xem trước nội dung import";
}

<link href="https://fonts.googleapis.com/css2?family=STIX+Two+Text&display=swap" rel="stylesheet">

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

        .page-header .back-arrow {
            cursor: pointer;
            color: #000;
            text-decoration: none;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .page-header .back-arrow:hover {
                background: rgba(122,75,22,0.1);
            }

            .page-header .back-arrow svg {
                width: 100%;
                height: 100%;
            }

        .page-header h2 {
            font-family: 'STIX Two Text', serif;
            font-weight: 700;
            font-size: 32px;
            margin-top: 26px;
            margin-bottom: 20px;
        }

    .preview-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .story-info {
        background-color: #FEE6D0;
        border: 2px solid #A6724E;
        border-radius: 15px;
        padding: 20px;
        margin-bottom: 30px;
        text-align: center;
    }

        .story-info h4 {
            font-family: 'STIX Two Text', serif;
            font-weight: 700;
            color: #000;
            margin: 0 0 10px 0;
        }

        .story-info .badge {
            font-size: 14px;
        }

    .chapter-card {
        background-color: #fff;
        border: 2px solid #A6724E;
        border-radius: 10px;
        margin-bottom: 20px;
        overflow: hidden;
    }

    .chapter-header {
        background-color: #A6724E;
        color: white;
        padding: 15px 20px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .chapter-header input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }

        .chapter-header h5 {
            margin: 0;
            flex-grow: 1;
            font-family: 'STIX Two Text', serif;
            font-weight: 600;
        }

        .chapter-header .badge {
            font-size: 14px;
        }

    .segment-list {
        padding: 20px;
    }

    .segment-item {
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 15px;
        background-color: #f8f9fa;
    }

        .segment-item h6 {
            font-weight: 600;
            color: #000;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .segment-item .char-count {
            font-size: 12px;
            color: #6c757d;
            font-weight: normal;
        }

        .segment-item .content-preview {
            max-height: 250px;
            overflow: hidden;
            position: relative;
            color: #495057;
            line-height: 1.8;
            transition: max-height 0.3s ease;
        }

        .segment-item .content-preview.expanded {
            max-height: none;
        }

            .segment-item .content-preview::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 60px;
                background: linear-gradient(transparent, #f8f9fa);
                pointer-events: none;
            }

            .segment-item .content-preview.expanded::after {
                display: none;
            }

        .segment-item .content-preview pre {
            white-space: pre-wrap;
            font-family: inherit;
            margin: 0;
            padding: 10px;
            background-color: white;
            border-radius: 6px;
            border: 1px solid #e9ecef;
        }

        .segment-item .expand-btn {
            margin-top: 10px;
            font-size: 14px;
            transition: all 0.2s;
        }

            .segment-item .expand-btn:hover {
                transform: translateY(-2px);
            }

    .action-buttons {
        position: sticky;
        bottom: 0;
        background-color: white;
        border-top: 2px solid #A6724E;
        padding: 20px;
        text-align: center;
        box-shadow: 0 -4px 8px rgba(0, 0, 0, 0.1);
    }

    .btn-action {
        padding: 12px 30px;
        font-size: 16px;
        border-radius: 8px;
        font-weight: 600;
        margin: 5px;
    }

    .select-all-container {
        background-color: #e7f3ff;
        border: 1px solid #0d6efd;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .select-all-container input[type="checkbox"] {
            width: 20px;
            height: 20px;
        }

        .select-all-container label {
            margin: 0;
            font-weight: 600;
            cursor: pointer;
        }
</style>

<div class="page-header">
    <a asp-action="Upload" asp-route-storyId="@Model.StoryId" class="back-arrow">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
    </a>
    <h2>XEM TRƯỚC NỘI DUNG IMPORT</h2>
</div>

<div class="preview-container">
    <div class="story-info">
        <h4>@Model.StoryTitle</h4>
        <span class="badge bg-success">Tìm thấy @Model.Chapters.Count chương</span>
        <span class="badge bg-info ms-2">Tổng @Model.Chapters.Sum(c => c.Segments.Count) đoạn</span>
    </div>

    <div class="select-all-container">
        <input type="checkbox" id="selectAllChapters" checked />
        <label for="selectAllChapters">Chọn/Bỏ chọn tất cả chương</label>
        <div class="ms-auto">
            <button type="button" class="btn btn-sm btn-outline-secondary" id="expandAllBtn">
                <i class="bi bi-arrows-expand"></i> Xem tất cả nội dung
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary d-none" id="collapseAllBtn">
                <i class="bi bi-arrows-collapse"></i> Thu gọn tất cả
            </button>
        </div>
    </div>

    <form asp-action="Confirm" method="post" id="confirmForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="storyId" value="@Model.StoryId" />

        @for (int i = 0; i < Model.Chapters.Count; i++)
        {
            var chapter = Model.Chapters[i];
            <div class="chapter-card">
                <div class="chapter-header">
                    <input type="checkbox" name="selectedChapters" value="@i" class="chapter-checkbox" checked />
                    <h5>@chapter.Title</h5>
                    <span class="badge bg-light text-dark">@chapter.Segments.Count đoạn</span>
                </div>

                <div class="segment-list">
                    @foreach (var segment in chapter.Segments)
                    {
                        <div class="segment-item">
                            <h6>
                                <i class="bi bi-file-text"></i>
                                @segment.Title
                                <span class="char-count">(@segment.Content.Length ký tự)</span>
                            </h6>
                            <div class="content-preview" data-full-content="@segment.Content">
                                @{
                                    var previewLimit = 500;
                                    var preview = segment.Content.Length > previewLimit
                                    ? segment.Content.Substring(0, previewLimit) + "..."
                                    : segment.Content;
                                }
                                <pre>@preview</pre>
                            </div>
                            @if (segment.Content.Length > previewLimit)
                            {
                                <button type="button" class="btn btn-sm btn-outline-primary expand-btn">
                                    <i class="bi bi-chevron-down"></i> Xem đầy đủ (còn @(segment.Content.Length - previewLimit) ký tự)
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <div class="action-buttons">
            <button type="submit" class="btn btn-success btn-action" id="confirmBtn">
                <i class="bi bi-check-circle"></i> Xác nhận và lưu
            </button>
            <a asp-action="Upload" asp-route-storyId="@Model.StoryId" class="btn btn-warning btn-action">
                <i class="bi bi-arrow-left"></i> Quay lại upload
            </a>
            <button type="button" class="btn btn-danger btn-action" data-bs-toggle="modal" data-bs-target="#cancelModal">
                <i class="bi bi-x-circle"></i> Hủy bỏ
            </button>
        </div>
    </form>
</div>

<!-- Modal xác nhận hủy -->
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Xác nhận hủy</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Bạn có chắc chắn muốn hủy bỏ? Tất cả dữ liệu đã phân tích sẽ bị mất.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Không</button>
                <form asp-action="Cancel" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="storyId" value="@Model.StoryId" />
                    <button type="submit" class="btn btn-danger">Có, hủy bỏ</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const previewLimit = 500;

            // Chọn/bỏ chọn tất cả
            $('#selectAllChapters').on('change', function () {
                $('.chapter-checkbox').prop('checked', $(this).is(':checked'));
            });

            // Cập nhật checkbox "chọn tất cả" khi checkbox riêng lẻ thay đổi
            $('.chapter-checkbox').on('change', function () {
                const allChecked = $('.chapter-checkbox').length === $('.chapter-checkbox:checked').length;
                $('#selectAllChapters').prop('checked', allChecked);
            });

            // Expand/Collapse từng segment
            $('.expand-btn').on('click', function () {
                const $btn = $(this);
                const $contentDiv = $btn.siblings('.content-preview');
                const fullContent = $contentDiv.data('full-content');
                const $pre = $contentDiv.find('pre');

                if ($btn.hasClass('expanded')) {
                    // Collapse
                    const preview = fullContent.length > previewLimit
                        ? fullContent.substring(0, previewLimit) + "..."
                        : fullContent;
                    $pre.text(preview);
                    const remaining = fullContent.length - previewLimit;
                    $btn.html('<i class="bi bi-chevron-down"></i> Xem đầy đủ (còn ' + remaining + ' ký tự)');
                    $btn.removeClass('expanded');
                    $contentDiv.removeClass('expanded');
                } else {
                    // Expand
                    $pre.text(fullContent);
                    $btn.html('<i class="bi bi-chevron-up"></i> Thu gọn');
                    $btn.addClass('expanded');
                    $contentDiv.addClass('expanded');
                }

                updateExpandCollapseAllButtons();
            });

            // Xem tất cả
            $('#expandAllBtn').on('click', function () {
                $('.expand-btn').not('.expanded').each(function () {
                    $(this).click();
                });
            });

            // Thu gọn tất cả
            $('#collapseAllBtn').on('click', function () {
                $('.expand-btn.expanded').each(function () {
                    $(this).click();
                });
            });

            // Cập nhật hiển thị nút Xem tất cả / Thu gọn tất cả
            function updateExpandCollapseAllButtons() {
                const totalExpandable = $('.expand-btn').length;
                const totalExpanded = $('.expand-btn.expanded').length;

                if (totalExpanded === 0) {
                    $('#expandAllBtn').removeClass('d-none');
                    $('#collapseAllBtn').addClass('d-none');
                } else if (totalExpanded === totalExpandable) {
                    $('#expandAllBtn').addClass('d-none');
                    $('#collapseAllBtn').removeClass('d-none');
                } else {
                    $('#expandAllBtn').removeClass('d-none');
                    $('#collapseAllBtn').removeClass('d-none');
                }
            }

            // Validation trước khi submit
            $('#confirmForm').on('submit', function (e) {
                const selectedCount = $('.chapter-checkbox:checked').length;
                if (selectedCount === 0) {
                    e.preventDefault();
                    alert('Vui lòng chọn ít nhất một chương để import!');
                    return false;
                }

                // Hiển thị loading
                $('#confirmBtn').html('<span class="spinner-border spinner-border-sm me-2"></span>Đang lưu...');
                $('#confirmBtn').prop('disabled', true);
            });
        });
    </script>
}
