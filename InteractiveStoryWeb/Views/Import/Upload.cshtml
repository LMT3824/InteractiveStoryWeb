@model InteractiveStoryWeb.ViewModels.ImportFileViewModel

@{
    ViewData["Title"] = "Import file truyện";
}

<link href="https://fonts.googleapis.com/css2?family=STIX+Two+Text&display=swap" rel="stylesheet">

<style>
    .page-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

        .page-header .back-arrow {
            cursor: pointer;
            color: #000;
            text-decoration: none;
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            vertical-align: middle;
        }

            .page-header .back-arrow:hover {
                background: rgba(122,75,22,0.1);
                color: #000000;
            }

            .page-header .back-arrow svg {
                width: 100%;
                height: 100%;
            }

        .page-header h2 {
            font-family: 'STIX Two Text', serif;
            font-weight: 700;
            font-size: 32px;
            margin-top: 26px;
            margin-bottom: 20px;
            line-height: 30px;
        }

    .import-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .import-card {
        background-color: #fff;
        border: 2px solid #A6724E;
        border-radius: 15px;
        padding: 40px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .story-info {
        background-color: #FEE6D0;
        border: 2px solid #A6724E;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 30px;
        text-align: center;
    }

        .story-info h4 {
            font-family: 'STIX Two Text', serif;
            font-weight: 700;
            color: #000;
            margin: 0;
        }

    .upload-area {
        border: 3px dashed #A6724E;
        border-radius: 10px;
        padding: 60px 20px;
        text-align: center;
        background-color: #f8f9fa;
        transition: all 0.3s;
        cursor: pointer;
    }

        .upload-area:hover {
            background-color: #FEE6D0;
            border-color: #7a4b16;
        }

        .upload-area.drag-over {
            background-color: #FEE6D0;
            border-color: #7a4b16;
        }

        .upload-area i {
            font-size: 64px;
            color: #A6724E;
            margin-bottom: 20px;
        }

        .upload-area p {
            font-size: 18px;
            color: #6c757d;
            margin: 10px 0;
        }

    .file-input {
        display: none;
    }

    .file-info {
        background-color: #e9ecef;
        border-radius: 8px;
        padding: 15px;
        margin-top: 20px;
        display: none;
    }

        .file-info.show {
            display: block;
        }

        .file-info .file-name {
            font-weight: 600;
            color: #000;
        }

        .file-info .file-size {
            color: #6c757d;
            font-size: 14px;
        }

    .instruction-box {
        background-color: #e7f3ff;
        border-left: 4px solid #0d6efd;
        padding: 20px;
        margin-top: 30px;
        border-radius: 5px;
    }

        .instruction-box h5 {
            font-weight: 600;
            color: #0d6efd;
            margin-bottom: 15px;
        }

        .instruction-box ul {
            margin-bottom: 0;
        }

        .instruction-box li {
            margin-bottom: 8px;
        }

    .btn-action {
        padding: 12px 30px;
        font-size: 16px;
        border-radius: 8px;
        font-weight: 600;
    }
</style>

<div class="page-header">
    <a asp-controller="Chapter" asp-action="Manage" asp-route-storyId="@ViewBag.StoryId" class="back-arrow">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
    </a>
    <h2>IMPORT FILE TRUYỆN</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="import-container">
    <div class="story-info">
        <h4>Truyện: @ViewBag.StoryTitle</h4>
    </div>

    <div class="import-card">
        <form asp-action="Upload" method="post" enctype="multipart/form-data" id="uploadForm">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="StoryId" />

            <div class="upload-area" id="uploadArea">
                <i class="bi bi-cloud-upload"></i>
                <p><strong>Kéo thả file vào đây hoặc nhấn để chọn file</strong></p>
                <p class="text-muted">Hỗ trợ: .docx, .pdf (tối đa 10MB)</p>
            </div>

            <input type="file" asp-for="File" class="file-input" id="fileInput" accept=".docx,.pdf" />
            <span asp-validation-for="File" class="text-danger"></span>

            <div class="file-info" id="fileInfo">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="file-name" id="fileName"></div>
                        <div class="file-size" id="fileSize"></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-danger" id="removeFileBtn">
                        <i class="bi bi-x-circle"></i> Xóa
                    </button>
                </div>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-primary btn-action" id="submitBtn" disabled>
                    <i class="bi bi-upload"></i> Tải lên và phân tích
                </button>
                <a asp-controller="Chapter" asp-action="Manage" asp-route-storyId="@ViewBag.StoryId" class="btn btn-secondary btn-action">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>
        </form>

        <div class="instruction-box">
            <h5><i class="bi bi-info-circle"></i> Hướng dẫn chuẩn bị file:</h5>
            <ul>
                <li><strong>Tiêu đề chương:</strong> Sử dụng Heading 1 (Ctrl+Alt+1) hoặc viết "Chương 1:", "Chương 2:" (có dấu :)</li>
                <li><strong>Tiêu đề đoạn:</strong> <span class="text-danger">BẮT BUỘC</span> sử dụng Heading 2 (Ctrl+Alt+2) hoặc viết "Đoạn 1:", "Đoạn 2:" (có dấu :)</li>
                <li><strong>Mỗi đoạn PHẢI có tiêu đề riêng:</strong> Không thể có nội dung mà không thuộc đoạn nào</li>
                <li><strong>Định dạng text:</strong> Hỗ trợ **in đậm**, *in nghiêng* (sẽ tự động chuyển sang Markdown)</li>
                <li><strong>Các ghi chú trong truyện: </strong> để tránh bị import, hãy để trong dấu [] hoặc đặt trước dòng là // </li>
                <li><strong>Choices:</strong> Sau khi import, bạn sẽ tự tạo các lựa chọn (choices) để liên kết các đoạn theo cốt truyện</li>
                <li><strong>Khuyến nghị:</strong> Dùng file .docx để có kết quả tốt nhất</li>
            </ul>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            const uploadArea = $('#uploadArea');
            const fileInput = $('#fileInput');
            const fileInfo = $('#fileInfo');
            const fileName = $('#fileName');
            const fileSize = $('#fileSize');
            const submitBtn = $('#submitBtn');
            const removeFileBtn = $('#removeFileBtn');

            // Click vào upload area để chọn file
            uploadArea.on('click', function () {
                fileInput.click();
            });

            // Xử lý khi chọn file
            fileInput.on('change', function (e) {
                handleFile(e.target.files[0]);
            });

            // Drag and drop
            uploadArea.on('dragover', function (e) {
                e.preventDefault();
                e.stopPropagation();
                uploadArea.addClass('drag-over');
            });

            uploadArea.on('dragleave', function (e) {
                e.preventDefault();
                e.stopPropagation();
                uploadArea.removeClass('drag-over');
            });

            uploadArea.on('drop', function (e) {
                e.preventDefault();
                e.stopPropagation();
                uploadArea.removeClass('drag-over');

                const files = e.originalEvent.dataTransfer.files;
                if (files.length > 0) {
                    fileInput[0].files = files;
                    handleFile(files[0]);
                }
            });

            // Xóa file
            removeFileBtn.on('click', function () {
                fileInput.val('');
                fileInfo.removeClass('show');
                submitBtn.prop('disabled', true);
            });

            function handleFile(file) {
                if (!file) return;

                // Kiểm tra định dạng
                const validExtensions = ['.docx', '.pdf'];
                const fileExtension = '.' + file.name.split('.').pop().toLowerCase();

                if (!validExtensions.includes(fileExtension)) {
                    alert('Chỉ hỗ trợ file .docx và .pdf');
                    fileInput.val('');
                    return;
                }

                // Kiểm tra kích thước (10MB)
                if (file.size > 10 * 1024 * 1024) {
                    alert('File không được vượt quá 10MB');
                    fileInput.val('');
                    return;
                }

                // Hiển thị thông tin file
                fileName.text(file.name);
                fileSize.text(formatFileSize(file.size));
                fileInfo.addClass('show');
                submitBtn.prop('disabled', false);
            }

            function formatFileSize(bytes) {
                if (bytes === 0) return '0 Bytes';
                const k = 1024;
                const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                const i = Math.floor(Math.log(bytes) / Math.log(k));
                return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
            }

            // Hiển thị loading khi submit
            $('#uploadForm').on('submit', function () {
                submitBtn.html('<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...');
                submitBtn.prop('disabled', true);
            });
        });
    </script>
}
